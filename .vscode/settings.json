{
    "python.formatting.provider": "yapf",
    "python.linting.enabled": true,
    "python.linting.flake8Enabled": true,
    "python.linting.ignorePatterns": [
        "**/site-packages/**/*.py",
        ".vscode/*.py"
    ],
    "python.linting.lintOnSave": true,
    "python.pythonPath": "${workspaceFolder}/.venv/bin/python",
}